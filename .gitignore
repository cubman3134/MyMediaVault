# Build output (CMake)
/build/
/build-clean/
/native/build/
/native/**/build/

# IDE / editor
.vs/
.vscode/
*.user

# OS
.DS_Store
Thumbs.db

# Cloudflare Wrangler local cache/state
.wrangler/
node_modules/

# Misc
*.log

# Superpowers scratch (audit screenshots, spike dumps, SDD working files)
.superpowers/

# Theme/addon registries are published as their own GitHub repos (nested .git);
# don't embed them in this repo.
/native/registry/

# Embedded provider dev credentials: the secrets files are build-time-only and
# must never be committed. Keep the format/instructions README, drop everything else.
/native/secrets/*
!/native/secrets/README.md

