// GENERATED at configure time by native/cmake/GenerateSecrets.cmake into the BUILD TREE.
// Do NOT edit, do NOT commit. Regenerated whenever native/secrets/screenscraper.secrets changes.
//
// Best-effort obfuscation (rolling XOR), NOT cryptography: it only keeps the plaintext dev
// credentials out of a `strings` scan of the shipped binary. Anyone holding the binary plus this
// source can trivially recover them. See native/secrets/README.md.
//
// The two arrays are the obfuscated devid+devpassword blob split in half, so no single array in the
// binary holds a contiguous credential. Empty (single 0 byte, all lengths 0) when the secrets file
// was absent at configure time. AddonContext::builtinCredential() joins + de-obfuscates on demand.
#pragma once

namespace mmv_secrets {

inline constexpr unsigned char kScreenScraperA[] = { @MMV_SS_ARRAY_A@ };
inline constexpr unsigned char kScreenScraperB[] = { @MMV_SS_ARRAY_B@ };
inline constexpr int kScreenScraperALen = @MMV_SS_LEN_A@;
inline constexpr int kScreenScraperBLen = @MMV_SS_LEN_B@;
inline constexpr int kScreenScraperDevidLen = @MMV_SS_DEVID_LEN@;
inline constexpr int kScreenScraperDevpasswordLen = @MMV_SS_DEVPASSWORD_LEN@;

} // namespace mmv_secrets
